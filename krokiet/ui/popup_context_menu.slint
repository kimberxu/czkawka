import { Button, VerticalBox } from "std-widgets.slint";
import { Callabler } from "callabler.slint";
import { ColorPalette } from "color_palette.slint";

export component PopupContextMenu inherits Rectangle {
    in property <int> selected_index: -1;
    callback show();
    callback close();

    // Use width/height 0 so it doesn't affect layout if placed in a layout, 
    // though in main_window it seems to be placed absolutely or in a layered way.
    width: 0px; 
    height: 0px;

    popup_window := PopupWindow {
        x: root.x;
        y: root.y;
        width: 250px;
        height: 220px;
        close-policy: close-on-click-outside;

        Rectangle {
            background: ColorPalette.popup_background;
            border-radius: 5px;
            border-width: 1px;
            border-color: ColorPalette.popup_border_color;
            
            VerticalBox {
                padding: 5px;
                spacing: 2px;
                
                Button { 
                    text: "Open File"; 
                    clicked => { 
                        Callabler.context_open_file(root.selected_index); 
                        popup_window.close(); 
                    } 
                }
                Button { 
                    text: "Open Folder"; 
                    clicked => { 
                        Callabler.context_open_folder(root.selected_index); 
                        popup_window.close(); 
                    } 
                }
                Button { 
                    text: "Select duplicates in this folder"; 
                    clicked => { 
                        Callabler.context_select_in_folder(root.selected_index); 
                        popup_window.close(); 
                    } 
                }
                Button { 
                    text: "Select duplicates in other folders"; 
                    clicked => { 
                        Callabler.context_select_other_folders(root.selected_index); 
                        popup_window.close(); 
                    } 
                }
                Button { 
                    text: "Protect this folder"; 
                    clicked => { 
                        Callabler.context_protect_folder(root.selected_index); 
                        popup_window.close(); 
                    } 
                }
            }
        }
    }

    show() => {
        popup_window.show();
    }
    close() => {
        popup_window.close();
    }
}
